@{
    ViewData["Title"] = "Employee Dashboard - ExpenseEZ";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Employee Dashboard - ExpenseEZ</title>

    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', Arial, sans-serif;
                background: #eef4fb;
                color: #0f172a;
            }

            .page {
                min-height: 100vh;
                padding: 30px;
            }

            .topbar {
                background: white;
                padding: 25px;
                border-radius: 22px;
                margin-bottom: 25px;
                box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

                .topbar h1 {
                    font-size: 30px;
                    color: #0f172a;
                }

                .topbar p {
                    color: #64748b;
                    margin-top: 6px;
                }

            .logout {
                background: #ef4444;
                color: white;
                padding: 11px 16px;
                border-radius: 12px;
                text-decoration: none;
                font-weight: 800;
            }

            .banner {
                background: linear-gradient(135deg, #0f5fc4, #16a34a);
                color: white;
                padding: 28px;
                border-radius: 24px;
                margin-bottom: 25px;
            }

                .banner h2 {
                    font-size: 28px;
                    margin-bottom: 8px;
                }

            .cards {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 18px;
                margin-bottom: 25px;
            }

            .card {
                background: white;
                padding: 24px;
                border-radius: 22px;
                box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
            }

                .card h3 {
                    font-size: 26px;
                    margin-bottom: 6px;
                }

                .card p {
                    color: #64748b;
                    font-weight: 700;
                }

            .grid {
                display: grid;
                grid-template-columns: 1.3fr 1fr;
                gap: 22px;
            }

            .panel {
                background: white;
                padding: 25px;
                border-radius: 22px;
                box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
            }

                .panel h2 {
                    margin-bottom: 18px;
                }

            .action-list {
                display: grid;
                gap: 14px;
            }

            .action {
                background: #f8fafc;
                padding: 18px;
                border-radius: 16px;
                border-left: 5px solid #0f5fc4;
            }

                .action strong {
                    display: block;
                    margin-bottom: 5px;
                }

            .status {
                padding: 8px 12px;
                border-radius: 20px;
                font-weight: 800;
                font-size: 12px;
            }

            .approved {
                background: #dcfce7;
                color: #15803d;
            }

            .pending {
                background: #fef3c7;
                color: #b45309;
            }

            .rejected {
                background: #fee2e2;
                color: #b91c1c;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            th {
                background: #f1f5f9;
                padding: 14px;
                text-align: left;
            }

            td {
                padding: 14px;
                border-bottom: 1px solid #e2e8f0;
                font-weight: 600;
            }

            @@media(max-width: 900px) {
                .cards {
                    grid-template-columns: repeat(2, 1fr);
                }

                .grid {
                    grid-template-columns: 1fr;
                }
            }

            @@media(max-width: 600px) {
                .cards {
                    grid-template-columns: 1fr;
                }

                .topbar {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 15px;
                }
            }
    </style>
</head>

<body>
    <div class="page">

        <div class="topbar">
            <div>
                <h1>Employee Dashboard</h1>
                <p>Submit expense claims, upload receipts, and track reimbursement status.</p>
            </div>

            <a class="logout" href="/Account/Login">Logout</a>
        </div>

        <div class="banner">
            <h2>Welcome to ExpenseEZ</h2>
            <p>This dashboard allows employees to manage their personal expense claims and reimbursement requests.</p>
        </div>

        <div class="cards">
            <div class="card">
                <h3>12</h3>
                <p>Total Claims</p>
            </div>

            <div class="card">
                <h3>5</h3>
                <p>Pending Claims</p>
            </div>

            <div class="card">
                <h3>6</h3>
                <p>Approved Claims</p>
            </div>

            <div class="card">
                <h3>₱8,500</h3>
                <p>Reimbursed</p>
            </div>
        </div>

        <div class="grid">

            <div class="panel">
                <h2>Recent Expense Claims</h2>

                <table>
                    <thead>
                        <tr>
                            <th>Claim</th>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>Transportation Claim</td>
                            <td>Travel</td>
                            <td>₱1,200</td>
                            <td><span class="status pending">Pending</span></td>
                        </tr>

                        <tr>
                            <td>Meal Allowance</td>
                            <td>Meals</td>
                            <td>₱850</td>
                            <td><span class="status approved">Approved</span></td>
                        </tr>

                        <tr>
                            <td>Office Supplies</td>
                            <td>Supplies</td>
                            <td>₱2,000</td>
                            <td><span class="status rejected">Rejected</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="panel">
                <h2>Employee Functions</h2>

                <div class="action-list">
                    <div class="action">
                        <strong>Submit Expense Claim</strong>
                        Create and submit a new expense request.
                    </div>

                    <div class="action">
                        <strong>Upload Receipts</strong>
                        Attach proof of payment or transaction receipts.
                    </div>

                    <div class="action">
                        <strong>View Claim Status</strong>
                        Track if claims are pending, approved, or rejected.
                    </div>

                    <div class="action">
                        <strong>View Reimbursement Status</strong>
                        Monitor if approved claims have been reimbursed.
                    </div>
                </div>
            </div>

        </div>
    </div>
</body>
</html>