@{
    ViewData["Title"] = "Submit Expense - ExpenseEZ";
}

<div class="employee-page">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="brand">
            <img src="/images/logo.png" />
        </div>

        <a class="nav-link">🏠 Dashboard</a>
        <a class="nav-link active">🧾 Submit Expense</a>
        <a class="nav-link">📎 Upload Receipts</a>
        <a class="nav-link">🔍 Expense Status</a>
        <a class="nav-link">💸 Reimbursement</a>
    </aside>

    <!-- MAIN -->
    <main class="main-content">

        <header class="topbar">
            <h1>Submit Expense Claim</h1>
            <p>Fill in the details to create a new expense claim.</p>
        </header>

        <div class="form-container">

            <form>

                <div class="form-row">

                    <div class="form-group">
                        <label>Expense Title</label>
                        <input type="text" placeholder="e.g. Travel to meeting" required />
                    </div>

                    <div class="form-group">
                        <label>Category</label>
                        <select required>
                            <option value="">Select Category</option>
                            <option>Transportation</option>
                            <option>Food</option>
                            <option>Office Supplies</option>
                            <option>Travel</option>
                        </select>
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group">
                        <label>Amount (₱)</label>
                        <input type="number" placeholder="Enter amount" required />
                    </div>

                    <div class="form-group">
                        <label>Date</label>
                        <input type="date" required />
                    </div>

                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea rows="4" placeholder="Enter expense details..."></textarea>
                </div>

                <div class="form-group">
                    <label>Upload Receipt</label>
                    <input type="file" />
                </div>

                <div class="buttons">
                    <button type="submit" class="btn-submit">Submit Claim</button>
                    <button type="reset" class="btn-clear">Clear</button>
                </div>

            </form>

        </div>

    </main>

</div>

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Arial, sans-serif;
        background: #f1f5f9;
    }

    .employee-page {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 260px;
        background: linear-gradient(180deg, #075bd1, #16a34a);
        color: white;
        padding: 20px;
        position: fixed;
        height: 100vh;
    }

    .brand {
        text-align: center;
        margin-bottom: 30px;
    }

        .brand img {
            width: 180px;
            background: white;
            padding: 10px;
            border-radius: 12px;
        }

    .nav-link {
        display: block;
        padding: 12px;
        margin-bottom: 8px;
        border-radius: 10px;
        color: white;
        text-decoration: none;
        font-weight: 600;
        cursor: pointer;
    }

        .nav-link.active,
        .nav-link:hover {
            background: rgba(255,255,255,0.2);
        }

    .main-content {
        margin-left: 260px;
        padding: 30px;
        width: 100%;
    }

    .topbar h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 800;
    }

    .topbar p {
        color: #64748b;
        margin-bottom: 25px;
    }

    .form-container {
        background: white;
        padding: 30px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        max-width: 900px;
    }

    .form-row {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    label {
        font-weight: 700;
        margin-bottom: 6px;
    }

    input, select, textarea {
        padding: 12px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        font-size: 14px;
    }

        input:focus, select:focus, textarea:focus {
            border-color: #075bd1;
            box-shadow: 0 0 0 3px rgba(7,91,209,0.2);
        }

    .buttons {
        margin-top: 20px;
        display: flex;
        gap: 15px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #075bd1, #16a34a);
        color: white;
        border: none;
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
    }

    .btn-clear {
        background: #e2e8f0;
        border: none;
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
    }

    @@media (max-width: 768px) {
        .form-row {
            flex-direction: column;
        }

        .sidebar {
            position: relative;
            width: 100%;
            height: auto;
        }

        .main-content {
            margin-left: 0;
        }
    }
</style>