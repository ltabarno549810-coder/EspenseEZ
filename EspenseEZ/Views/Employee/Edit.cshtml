@{
    ViewData["Title"] = "Edit Expense Claim - ExpenseEZ";
}

<div class="employee-page">

    <aside class="sidebar">
        <div class="brand">
            <img src="/images/logo.png" />
        </div>

        <a class="nav-link">🏠 Dashboard</a>
        <a class="nav-link active">✏️ Edit Claim</a>
        <a class="nav-link">🧾 Submit Expense</a>
        <a class="nav-link">🔍 Expense Status</a>
        <a class="nav-link">💸 Reimbursement</a>
    </aside>

    <main class="main-content">

        <header class="topbar">
            <h1>Edit Expense Claim</h1>
            <p>Update your submitted expense claim information.</p>
        </header>

        <div class="form-container">

            <div class="claim-info">
                <div>
                    <strong>Claim No:</strong>
                    <span>CLM-002</span>
                </div>
                <div>
                    <strong>Status:</strong>
                    <span class="status pending">Pending</span>
                </div>
            </div>

            <form>

                <div class="form-row">
                    <div class="form-group">
                        <label>Expense Title</label>
                        <input type="text" value="Office Supplies Purchase" required />
                    </div>

                    <div class="form-group">
                        <label>Category</label>
                        <select required>
                            <option>Transportation</option>
                            <option selected>Office Supplies</option>
                            <option>Food</option>
                            <option>Travel</option>
                            <option>Others</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Amount (₱)</label>
                        <input type="number" value="1250" required />
                    </div>

                    <div class="form-group">
                        <label>Date Submitted</label>
                        <input type="date" value="2026-04-12" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea rows="4">Purchased bond paper, folders, pens, and other office supplies needed for department operations.</textarea>
                </div>

                <div class="form-group">
                    <label>Replace Receipt</label>
                    <input type="file" />
                    <small>Current receipt: receipt-office-supplies.pdf</small>
                </div>

                <div class="buttons">
                    <button type="submit" class="btn-update">Update Claim</button>
                    <button type="reset" class="btn-reset">Reset Changes</button>
                    <a href="/Employee/Dashboard" class="btn-cancel">Cancel</a>
                </div>

            </form>

        </div>

    </main>

</div>

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Arial, sans-serif;
        background: #f1f5f9;
    }

    .employee-page {
        display: flex;
        min-height: 100vh;
    }

    .sidebar {
        width: 260px;
        background: linear-gradient(180deg, #075bd1, #16a34a);
        color: white;
        padding: 20px;
        position: fixed;
        height: 100vh;
    }

    .brand {
        text-align: center;
        margin-bottom: 30px;
    }

        .brand img {
            width: 180px;
            background: white;
            padding: 10px;
            border-radius: 12px;
        }

    .nav-link {
        display: block;
        padding: 12px;
        margin-bottom: 8px;
        border-radius: 10px;
        color: white;
        text-decoration: none;
        font-weight: 600;
        cursor: pointer;
    }

        .nav-link.active,
        .nav-link:hover {
            background: rgba(255,255,255,0.2);
        }

    .main-content {
        margin-left: 260px;
        padding: 30px;
        width: 100%;
    }

    .topbar h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
    }

    .topbar p {
        color: #64748b;
        margin-bottom: 25px;
    }

    .form-container {
        background: white;
        padding: 30px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        max-width: 900px;
    }

    .claim-info {
        display: flex;
        justify-content: space-between;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 16px;
        border-radius: 14px;
        margin-bottom: 25px;
        color: #334155;
    }

        .claim-info span {
            margin-left: 6px;
        }

    .status {
        padding: 6px 12px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 700;
    }

    .pending {
        background: #fef3c7;
        color: #b45309;
    }

    .form-row {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        flex: 1;
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

    label {
        font-weight: 700;
        margin-bottom: 6px;
        color: #334155;
    }

    input, select, textarea {
        padding: 12px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        font-size: 14px;
        outline: none;
    }

        input:focus, select:focus, textarea:focus {
            border-color: #075bd1;
            box-shadow: 0 0 0 3px rgba(7,91,209,0.2);
        }

    small {
        margin-top: 8px;
        color: #64748b;
        font-weight: 600;
    }

    .buttons {
        margin-top: 20px;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .btn-update {
        background: linear-gradient(135deg, #075bd1, #16a34a);
        color: white;
        border: none;
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
    }

    .btn-reset {
        background: #e2e8f0;
        border: none;
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
        color: #334155;
    }

    .btn-cancel {
        background: #fee2e2;
        color: #b91c1c;
        text-decoration: none;
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 700;
    }

    @@media (max-width: 768px) {
        .form-row,
        .claim-info {
            flex-direction: column;
            gap: 12px;
        }

        .sidebar {
            position: relative;
            width: 100%;
            height: auto;
        }

        .employee-page {
            flex-direction: column;
        }

        .main-content {
            margin-left: 0;
        }
    }
</style>