@{
    Layout = null;
    ViewData["Title"] = "Login - ExpenseEZ";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - ExpenseEZ</title>

    <style>
            * {
                box-sizing: border-box;
            }

            html, body {
                margin: 0;
                padding: 0;
                width: 100%;
                height: 100%;
                font-family: 'Segoe UI', Arial, sans-serif;
                overflow: hidden;
            }

            body {
                background: linear-gradient(135deg, #031b4e, #075bd1, #16a34a);
            }

            .login-page {
                width: 100vw;
                height: 100vh;
                position: relative;
                display: flex;
                justify-content: center;
                align-items: center;
                overflow: hidden;
            }

            .orb {
                position: absolute;
                border-radius: 50%;
                filter: blur(5px);
                opacity: 0.55;
                animation: floatOrb 7s ease-in-out infinite;
            }

            .orb-1 {
                width: 320px;
                height: 320px;
                background: #38bdf8;
                top: -80px;
                left: -80px;
            }

            .orb-2 {
                width: 280px;
                height: 280px;
                background: #22c55e;
                bottom: -90px;
                right: -70px;
                animation-delay: 1.5s;
            }

            .orb-3 {
                width: 180px;
                height: 180px;
                background: #ffffff;
                top: 15%;
                right: 18%;
                opacity: 0.18;
                animation-delay: 2.5s;
            }

            @@keyframes floatOrb {
                0%, 100% {
                    transform: translateY(0);
                }

                50% {
                    transform: translateY(-25px);
                }
            }

            .glass-card {
                position: relative;
                z-index: 5;
                width: 430px;
                padding: 38px;
                border-radius: 28px;
                background: rgba(255, 255, 255, 0.16);
                border: 1px solid rgba(255, 255, 255, 0.35);
                box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
                backdrop-filter: blur(20px);
                color: white;
            }

            .logo-box {
                background: rgba(255,255,255,0.95);
                padding: 18px;
                border-radius: 20px;
                margin-bottom: 24px;
                box-shadow: 0 15px 35px rgba(0,0,0,0.22);
            }

            .logo {
                width: 230px;
                max-width: 100%;
                display: block;
                margin: auto;
                animation: logoFloat 3s ease-in-out infinite;
            }

            @@keyframes logoFloat {
                0%, 100% {
                    transform: translateY(0);
                }

                50% {
                    transform: translateY(-7px);
                }
            }

            h2 {
                margin: 0;
                text-align: center;
                font-size: 32px;
                font-weight: 900;
            }

            .subtitle {
                text-align: center;
                margin: 8px 0 26px;
                color: rgba(255,255,255,0.82);
            }

            .error-message {
                background: rgba(239, 68, 68, 0.20);
                color: #fecaca;
                border: 1px solid rgba(254, 202, 202, 0.45);
                padding: 12px;
                border-radius: 14px;
                text-align: center;
                font-weight: 800;
                margin-bottom: 18px;
            }

            .form-group {
                margin-bottom: 19px;
            }

            label {
                display: block;
                font-weight: 800;
                margin-bottom: 8px;
                color: rgba(255,255,255,0.95);
            }

            .input-box {
                height: 56px;
                border-radius: 16px;
                background: rgba(255,255,255,0.18);
                border: 1px solid rgba(255,255,255,0.32);
                display: flex;
                align-items: center;
                padding: 0 15px;
                transition: 0.25s;
            }

                .input-box:focus-within {
                    background: rgba(255,255,255,0.25);
                    border-color: white;
                    box-shadow: 0 0 0 4px rgba(255,255,255,0.16);
                }

            .input-icon {
                margin-right: 12px;
                font-size: 19px;
            }

            .input-box input {
                width: 100%;
                height: 100%;
                border: none;
                outline: none;
                background: transparent;
                color: white;
                font-size: 15px;
            }

                .input-box input::placeholder {
                    color: rgba(255,255,255,0.65);
                }

            .eye-btn {
                background: transparent;
                border: none;
                color: white;
                cursor: pointer;
                font-size: 18px;
            }

            .row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin: 5px 0 24px;
                font-size: 14px;
            }

                .row label {
                    margin: 0;
                    font-weight: 700;
                }

                .row a {
                    color: #bfdbfe;
                    text-decoration: none;
                    font-weight: 800;
                }

            .btn-login {
                width: 100%;
                height: 58px;
                border: none;
                border-radius: 16px;
                background: linear-gradient(135deg, #ffffff, #dbeafe);
                color: #075bd1;
                font-size: 17px;
                font-weight: 900;
                cursor: pointer;
                box-shadow: 0 14px 30px rgba(0,0,0,0.25);
                transition: 0.25s;
            }

                .btn-login:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 18px 38px rgba(0,0,0,0.35);
                }

            .footer-note {
                text-align: center;
                margin-top: 20px;
                color: rgba(255,255,255,0.72);
                font-size: 13px;
            }

            @@media (max-width: 600px) {
                .glass-card {
                    width: calc(100% - 32px);
                    padding: 30px 24px;
                }

                .logo {
                    width: 200px;
                }
            }
    </style>
</head>

<body>
    <main class="login-page">

        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <div class="glass-card">

            <div class="logo-box">
                <img src="/images/logo.png" class="logo" alt="ExpenseEZ Logo" />
            </div>

            <h2>Welcome Back</h2>
            <p class="subtitle">Login to access your ExpenseEZ account</p>

            @if (ViewBag.Error != null)
            {
                <div class="error-message">
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-controller="Account" asp-action="Login">

                <div class="form-group">
                    <label>Username</label>
                    <div class="input-box">
                        <span class="input-icon">👤</span>
                        <input type="text" name="username" placeholder="Enter your username" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-box">
                        <span class="input-icon">🔒</span>
                        <input type="password" id="passwordInput" name="password" placeholder="Enter your password" required />
                        <button type="button" class="eye-btn" onclick="togglePassword()">👁️</button>
                    </div>
                </div>

                <div class="row">
                    <label>
                        <input type="checkbox" />
                        Remember me
                    </label>

                    <a href="#">Forgot password?</a>
                </div>

                <button type="submit" class="btn-login">
                    Login
                </button>

                <p class="footer-note">
                    Secure role-based access for Admin and Employee accounts
                </p>

            </form>

        </div>

    </main>

    <script>
            function togglePassword() {
                const passwordInput = document.getElementById("passwordInput");
                const eyeButton = document.querySelector(".eye-btn");

                if (passwordInput.type === "password") {
                    passwordInput.type = "text";
                    eyeButton.textContent = "🙈";
                } else {
                    passwordInput.type = "password";
                    eyeButton.textContent = "👁️";
                }
            }
    </script>
</body>
</html>