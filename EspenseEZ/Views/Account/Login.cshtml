@{
    ViewData["Title"] = "Login - ExpenseEZ";
}

<div class="expenseez-page">

    <div class="bg-circle circle-one"></div>
    <div class="bg-circle circle-two"></div>
    <div class="dot-pattern dots-left"></div>
    <div class="dot-pattern dots-right"></div>

    <div class="wave wave-blue"></div>
    <div class="wave wave-dark"></div>
    <div class="wave wave-green"></div>

    <div class="login-layout">

        <!-- LEFT BRANDING -->
        <section class="brand-panel">
            <div class="brand-inner">

                <img src="/images/logo.png" class="main-logo" />

                <div class="small-line"></div>

                <h2>Smart. Simple. Transparent.</h2>

                <p>
                    Manage expenses, track approvals, and process reimbursements efficiently
                    in one secure platform.
                </p>

                <div class="cityline"></div>

                <div class="feature-card">
                    <div class="feature-item">
                        <div class="feature-icon">🛡️</div>
                        <h4>Secure Access</h4>
                        <span>Role-based security</span>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">⏱️</div>
                        <h4>Faster Workflow</h4>
                        <span>Automated approvals</span>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">📄</div>
                        <h4>Better Tracking</h4>
                        <span>Real-time status updates</span>
                    </div>

                    <div class="feature-item">
                        <div class="feature-icon">📊</div>
                        <h4>Data Insights</h4>
                        <span>Reports and analytics</span>
                    </div>
                </div>

            </div>
        </section>

        <!-- RIGHT LOGIN -->
        <section class="form-panel">
            <div class="login-card">

                <div class="shield-icon">🛡️</div>

                <h1>Welcome Back!</h1>
                <p class="login-subtitle">Please log in to continue.</p>

                <form method="post">

                    <div class="form-group">
                        <label>Email / Username</label>
                        <div class="input-box">
                            <span class="input-icon">👤</span>
                            <input type="text" placeholder="Enter your email or username" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <div class="input-box">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="passwordInput" placeholder="Enter your password" required />
                            <button type="button" class="eye-btn" onclick="togglePassword()">👁️</button>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Login as</label>
                        <div class="input-box">
                            <span class="input-icon">👥</span>
                            <select required>
                                <option value="">Select your role</option>
                                <option>Employee</option>
                                <option>Manager</option>
                                <option>Finance Officer</option>
                                <option>Admin</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <label class="remember">
                            <input type="checkbox" />
                            Remember me
                        </label>

                        <a href="#">Forgot password?</a>
                    </div>

                    <button type="submit" class="login-btn">
                        🔐 Login
                    </button>

                    <div class="divider">
                        <span></span>
                        <p>ExpenseEZ Security Commitment</p>
                        <span></span>
                    </div>

                    <div class="security-box">
                        <div>🛡️</div>
                        <p>
                            Your data is protected with enterprise-grade security and activity monitoring.
                        </p>
                    </div>

                </form>

            </div>
        </section>

    </div>
</div>

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: 'Segoe UI', Arial, sans-serif;
        background: #eaf4ff;
        overflow-x: hidden;
    }

    .expenseez-page {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #eef7ff 0%, #dcebff 50%, #f8fbff 100%);
    }

    .login-layout {
        position: relative;
        z-index: 5;
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        align-items: center;
        padding: 55px 70px;
        gap: 50px;
    }

    .brand-panel {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .brand-inner {
        width: 100%;
        max-width: 650px;
    }

    .main-logo {
        width: 480px;
        max-width: 100%;
        margin-bottom: 20px;
        animation: logoFloat 3s ease-in-out infinite;
        filter: drop-shadow(0 10px 18px rgba(37, 99, 235, 0.18));
    }

        .main-logo:hover {
            transform: scale(1.04);
            filter: drop-shadow(0 0 18px rgba(37, 99, 235, 0.35));
        }

    @@keyframes logoFloat {
        0% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-10px);
        }

        100% {
            transform: translateY(0);
        }
    }

    .small-line {
        width: 95px;
        height: 3px;
        background: linear-gradient(90deg, #0f5fc4, #2bb95d);
        border-radius: 20px;
        margin: 5px 0 35px;
        position: relative;
    }

        .small-line::after {
            content: "";
            position: absolute;
            right: -6px;
            top: -3px;
            width: 9px;
            height: 9px;
            background: #2bb95d;
            border-radius: 50%;
        }

    .brand-inner h2 {
        font-size: 28px;
        color: #10174a;
        margin-bottom: 16px;
        font-weight: 800;
    }

    .brand-inner p {
        color: #1f2a44;
        font-size: 17px;
        line-height: 1.7;
        max-width: 520px;
    }

    .feature-card {
        margin-top: 220px;
        background: rgba(10, 80, 170, 0.55);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 24px;
        padding: 25px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        box-shadow: 0 18px 45px rgba(0, 64, 150, 0.25);
    }

    .feature-item {
        text-align: center;
        color: white;
    }

    .feature-icon {
        width: 58px;
        height: 58px;
        margin: 0 auto 12px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
    }

    .feature-item h4 {
        margin: 0 0 7px;
        font-size: 15px;
        font-weight: 800;
    }

    .feature-item span {
        font-size: 13px;
        line-height: 1.5;
        display: block;
    }

    .form-panel {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        width: 100%;
        max-width: 565px;
        background: rgba(255, 255, 255, 0.96);
        padding: 50px 55px;
        border-radius: 23px;
        box-shadow: 0 24px 60px rgba(15, 58, 120, 0.18);
        border: 1px solid rgba(255, 255, 255, 0.9);
    }

    .shield-icon {
        width: 60px;
        height: 60px;
        background: #e8f2ff;
        color: #0b5dc7;
        margin: 0 auto 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 27px;
    }

    .login-card h1 {
        text-align: center;
        color: #081344;
        font-size: 31px;
        margin: 0;
        font-weight: 850;
    }

    .login-subtitle {
        text-align: center;
        color: #637089;
        margin: 12px 0 35px;
        font-size: 17px;
    }

    .form-group {
        margin-bottom: 22px;
    }

        .form-group label {
            display: block;
            font-weight: 700;
            color: #111b4d;
            margin-bottom: 9px;
        }

    .input-box {
        height: 55px;
        border: 1px solid #ccd6e5;
        border-radius: 9px;
        background: white;
        display: flex;
        align-items: center;
        padding: 0 15px;
        transition: 0.25s;
    }

        .input-box:focus-within {
            border-color: #1260c7;
            box-shadow: 0 0 0 4px rgba(18, 96, 199, 0.12);
        }

    .input-icon {
        color: #6b7890;
        font-size: 19px;
        margin-right: 14px;
    }

    .input-box input,
    .input-box select {
        width: 100%;
        height: 100%;
        border: none;
        outline: none;
        background: transparent;
        font-size: 16px;
        color: #26334d;
    }

        .input-box input::placeholder {
            color: #7c879a;
        }

    .eye-btn {
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 18px;
        padding: 5px;
    }

    .form-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 2px 0 25px;
        font-size: 15px;
    }

    .remember {
        display: flex;
        gap: 8px;
        align-items: center;
        color: #1f2a44;
        font-weight: 600;
    }

    .form-row a {
        color: #075dca;
        text-decoration: none;
        font-weight: 600;
    }

    .login-btn {
        width: 100%;
        height: 58px;
        border: none;
        border-radius: 9px;
        background: linear-gradient(135deg, #075bd1, #2d93e9);
        color: white;
        font-size: 20px;
        font-weight: 800;
        cursor: pointer;
        transition: 0.25s;
        box-shadow: 0 10px 22px rgba(7, 91, 209, 0.28);
    }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 28px rgba(7, 91, 209, 0.35);
        }

    .divider {
        display: flex;
        align-items: center;
        gap: 14px;
        margin: 35px 0 25px;
    }

        .divider span {
            height: 1px;
            flex: 1;
            background: #ccd6e5;
        }

        .divider p {
            margin: 0;
            color: #66738c;
            font-size: 14px;
            white-space: nowrap;
        }

    .security-box {
        display: flex;
        align-items: center;
        gap: 15px;
        color: #536075;
        font-size: 15px;
        line-height: 1.6;
    }

        .security-box div {
            font-size: 28px;
            color: #0b5dc7;
        }

        .security-box p {
            margin: 0;
        }

    .wave {
        position: absolute;
        left: -5%;
        bottom: -160px;
        width: 115%;
        height: 370px;
        border-radius: 50% 50% 0 0;
        transform: rotate(-3deg);
        z-index: 1;
    }

    .wave-blue {
        background: #0b5dc7;
        bottom: -110px;
    }

    .wave-dark {
        background: #003f97;
        bottom: -155px;
        transform: rotate(4deg);
    }

    .wave-green {
        background: #2bb95d;
        width: 45%;
        height: 260px;
        left: auto;
        right: -130px;
        bottom: -120px;
        transform: rotate(-15deg);
    }

    .bg-circle {
        position: absolute;
        border-radius: 50%;
        background: rgba(120, 180, 240, 0.14);
        z-index: 0;
    }

    .circle-one {
        width: 150px;
        height: 150px;
        top: -35px;
        left: 27%;
    }

    .circle-two {
        width: 250px;
        height: 250px;
        top: -95px;
        right: -55px;
    }

    .dot-pattern {
        position: absolute;
        width: 130px;
        height: 130px;
        background-image: radial-gradient(rgba(70, 145, 230, 0.18) 3px, transparent 3px);
        background-size: 18px 18px;
        z-index: 0;
    }

    .dots-left {
        top: 15px;
        left: 10px;
    }

    .dots-right {
        right: 25px;
        top: 275px;
    }

    .cityline {
        position: absolute;
        left: 80px;
        bottom: 260px;
        width: 46%;
        height: 150px;
        opacity: 0.24;
        background: linear-gradient(to top, #0b5dc7 0 55px, transparent 55px), linear-gradient(to top, #0b5dc7 0 105px, transparent 105px), linear-gradient(to top, #0b5dc7 0 80px, transparent 80px), linear-gradient(to top, #0b5dc7 0 120px, transparent 120px), linear-gradient(to top, #0b5dc7 0 70px, transparent 70px), linear-gradient(to top, #0b5dc7 0 95px, transparent 95px);
        background-size: 45px 100%, 55px 100%, 40px 100%, 60px 100%, 45px 100%, 50px 100%;
        background-position: 0 bottom, 90px bottom, 180px bottom, 285px bottom, 400px bottom, 505px bottom;
        background-repeat: no-repeat;
        z-index: 2;
    }

    @@media (max-width: 1100px) {
        .login-layout {
            grid-template-columns: 1fr;
            padding: 40px 25px;
        }

        .brand-panel {
            display: none;
        }

        .login-card {
            max-width: 520px;
        }

        .wave {
            height: 280px;
        }
    }
</style>

<script>
    function togglePassword() {
        const passwordInput = document.getElementById("passwordInput");
        const eyeButton = document.querySelector(".eye-btn");

        if (passwordInput.type === "password") {
            passwordInput.type = "text";
            eyeButton.textContent = "🙈";
        } else {
            passwordInput.type = "password";
            eyeButton.textContent = "👁️";
        }
    }
</script>